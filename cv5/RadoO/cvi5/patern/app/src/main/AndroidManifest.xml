<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.fmph.kai.patern">

    <application
        android:allowBackup="true"
        android:icon="@drawable/ic_lock"
        android:label="@string/app_name"
        android:roundIcon="@drawable/ic_lock"
        android:supportsRtl="true"
        android:theme="@style/AppTheme">
        <activity android:name=".MainActivity">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <activity android:name=".ZadajKod">
            <intent-filter>
                <action android:name="com.fmph.kai.patern.ZadojKod" />

                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
        </activity>
        <activity android:name=".Odomkni">
            <intent-filter>
                <action android:name="com.fmph.kai.patern.Odomkni" />

                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
        </activity>
    </application>

</manifest>